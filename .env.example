# nginx 호스트 바인딩 — kro.kr + Let's Encrypt HTTP-01: 인터넷에서 도메인:80 이 이 컨테이너까지 와야 함.
# 권장: 호스트 80 이 비어 있으면 아래처럼 80 사용. 80 이 이미 쓰이면 NGINX_HTTP_PORT=8188 + 공유기 외부80→내부8188,
# 또는 호스트 nginx 가 80 을 받고 127.0.0.1:8188 으로 프록시 → infra/nginx/host-forward-80.example.conf 참고(302 로 사설 HTTPS 금지).
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=8443

POSTGRES_USER=nodex
POSTGRES_PASSWORD=nodex
POSTGRES_DB=nodex

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,nginx,192.168.0.16,106.255.245.242,www.nodexstudio.kro.kr,nodexstudio.kro.kr,api.nodexstudio.kro.kr

# 프론트 공개 URL (OAuth 완료 후 이동). HTTPS 권장
FRONTEND_PUBLIC_URL=https://www.nodexstudio.kro.kr/

# 분리 배포: API 전용 오리진. HTTPS 권장
PUBLIC_API_BASE_URL=https://api.nodexstudio.kro.kr

# Let's Encrypt — 본인 실제 이메일 (Gmail 등). *@example.com 은 발급 거절됨
CERTBOT_EMAIL=
# 쉼표로 구분. apex(nodexstudio.kro.kr)는 DNS A 없으면 빼기
# CERTBOT_DOMAINS=www.nodexstudio.kro.kr,api.nodexstudio.kro.kr
# 1=스테이징(브라우저 비신뢰, 한도 별도). kro.kr 한도 초과 시 연동 테스트용
# CERTBOT_STAGING=0
# HTTP-01 이 막히면(앞단 302 등): ./infra/scripts/init-letsencrypt-dns01.sh — DNS 패널에 TXT(_acme-challenge) 수동 추가

# Google OAuth — Google Cloud「승인된 리디렉션 URI」는 공인 IP만 넣는 방식이 아니라 https + 도메인(또는 로컬 개발용 localhost)이 일반적입니다.
# 운영은 https://api.…/auth/google/callback 처럼 고정 URL 이라서, 그 전제가 TLS 인증서(위 Let's Encrypt) + DNS 입니다.
GOOGLE_OAUTH_REDIRECT_URI=https://api.nodexstudio.kro.kr/auth/google/callback

# 비워두면 FRONTEND_PUBLIC_URL 기준으로 CORS 허용
# CORS_ALLOWED_ORIGINS=https://www.nodexstudio.kro.kr,https://nodexstudio.kro.kr

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=nodex

GOOGLE_OAUTH_CLIENT_ID=change-me
GOOGLE_OAUTH_CLIENT_SECRET=change-me
GEMINI_API_KEY=change-me
